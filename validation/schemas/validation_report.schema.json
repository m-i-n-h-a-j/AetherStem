{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AetherStem Validation Report",
  "type": "object",
  "required": ["version", "started_at", "passed", "summary", "checks"],
  "properties": {
    "version": {"type": "string"},
    "started_at": {"type": "number"},
    "passed": {"type": "boolean"},
    "summary": {
      "type": "object",
      "required": ["passed", "failed", "skipped"],
      "properties": {
        "passed": {"type": "integer"},
        "failed": {"type": "integer"},
        "skipped": {"type": "integer"}
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tier", "name", "status", "details", "duration_ms"],
        "properties": {
          "tier": {"type": "string"},
          "name": {"type": "string"},
          "status": {"enum": ["passed", "failed", "skipped"]},
          "details": {"type": "object"},
          "duration_ms": {"type": "number"}
        }
      }
    }
  }
}
